# =============================================================
# Lullow environment configuration
# Copy to .env and fill in the keys you have. EVERY integration
# has a graceful mock fallback, so the app runs fully with NO keys.
# =============================================================

# --- Core app ---
APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated origins allowed by CORS (the Vite dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Anthropic legacy placeholders (not used by the prompt pipeline) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_DEEP_MODEL=claude-opus-4-8

# --- Fetch.ai ASI One: only live prompt generation provider ---
PROMPT_PROVIDER=anthropic
# Either name works; prefer FETCHAI_API_KEY for this app.
FETCHAI_API_KEY=
ASI_ONE_API_KEY=
FETCHAI_BASE_URL=https://api.asi1.ai/v1/chat/completions
FETCHAI_MODEL=asi1

# --- Deepgram: speech-to-text + text-to-speech ---
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
# A soft, warm TTS voice for bedtime narration.
DEEPGRAM_TTS_MODEL=aura-2-cora-en

# --- Redis: family/story-world memory + parent safety settings ---
# If empty, an in-memory fake store is used (data resets on restart).
REDIS_URL=redis://localhost:6379/0
# Optional stronger split: set either of these to a different Redis deployment.
REDIS_APP_URL=
REDIS_PROFILE_URL=
# Logical DB split used in development. In production, separate Redis instances
# or ACL-separated deployments are safer than logical DBs.
REDIS_APP_DB=0
REDIS_PROFILE_DB=1
# Compress larger JSON payloads such as stories/RAG docs before writing Redis.
REDIS_COMPRESS_JSON=true
REDIS_COMPRESS_MIN_BYTES=1024

# --- Auth/session demo defaults ---
SESSION_TTL_SECONDS=86400
DEMO_USERNAME=demo_parent
DEMO_PASSWORD=lullow-demo
DEMO_CHILD_ID=child_001

# --- Pika: image-to-video low-motion picture-book animation ---
PIKA_API_KEY=
PIKA_BASE_URL=https://api.pika.art

# --- Image model: per-page picture-book illustration (image-first) ---
# Provider: "gemini" (Gemini Flash Image), "openai" (gpt-image-1), or "midjourney"
IMAGE_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
MIDJOURNEY_API_KEY=
MIDJOURNEY_BASE_URL=
OPENAI_API_KEY=

# --- Arize: evaluation / observability of story safety + tone ---
ARIZE_API_KEY=
ARIZE_SPACE_ID=
ARIZE_PROJECT_NAME=lullow

# --- Terac: parent-style annotation loop ---
TERAC_API_KEY=
TERAC_BASE_URL=https://api.terac.ai

# --- Govee: physical Lullow mood lamp (optional) ---
# Leave blank to run without hardware (lamp calls become silent no-ops).
# Uses the Govee v2 developer API (openapi.api.govee.com).
GOVEE_API_KEY=
GOVEE_DEVICE=
GOVEE_SKU=
